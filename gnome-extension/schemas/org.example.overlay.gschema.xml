<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.example.overlay" path="/org/example/overlay/">
    <key name="autostart" type="b">
      <default>true</default>
      <summary>Show overlay when extension is enabled</summary>
      <description>If true, the built-in GNOME Shell overlay is shown when the extension starts.</description>
    </key>

    <key name="title" type="s">
      <default>'Activate Linux'</default>
      <summary>Overlay title</summary>
      <description>The large overlay title text.</description>
    </key>

    <key name="text" type="s">
      <default>'Go to Settings to activate Linux.'</default>
      <summary>Overlay body text</summary>
      <description>The smaller overlay body text.</description>
    </key>
  </schema>
</schemalist>
